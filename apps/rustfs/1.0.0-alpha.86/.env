# 数据持久化路径 [必填] 
RUSTFS_ROOT_PATH=/home/rustfs

# WebUI 端口 [必填] 
PANEL_APP_PORT_HTTP=9001

# API 端口 [必填] 
PANEL_APP_PORT_API=9000

# 管理员账号 [必填] 
RUSTFS_ACCESS_KEY=rustfsadmin

# 管理员密码 [必填] 
RUSTFS_SECRET_KEY=rustfsadmin

# 域名 
RUSTFS_SERVER_DOMAINS=example.com

# 启用控制台 [必填] 
RUSTFS_CONSOLE_ENABLE=true

